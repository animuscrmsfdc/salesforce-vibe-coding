# .claudeignore — files and directories Claude Code should not read
# Uses .gitignore-style glob patterns.

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
coverage/
*.lock
package-lock.json
yarn.lock

# ── Salesforce tooling cache ───────────────────────────────────────────────────
.sf/
.sfdx/
.localdevserver/
.pmdCache
.eslintcache
deploy-options.json

# ── Build / generated output ───────────────────────────────────────────────────
dist/
build/
out/
__pycache__/
**/__pycache__/
.venv/
**/.venv/
venv/
**/venv/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# ── Secrets / environment ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Git internals ─────────────────────────────────────────────────────────────
.git/

# ── Claude Code local / personal files ────────────────────────────────────────
CLAUDE.local.md
.claude/settings.local.json

# ── Large binary / media assets ───────────────────────────────────────────────
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
*.pdf
*.zip
*.tar.gz
*.tgz
*.mp4
*.mov

# ── Jest snapshot artefacts ───────────────────────────────────────────────────
**/__snapshots__/

# ── SFDX typings (generated, not authored) ────────────────────────────────────
.sfdx/typings/
