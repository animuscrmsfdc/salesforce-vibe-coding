# AnimusCRM — Required Environment Variables
# Copy this file to .env (gitignored) and fill in your values.
# In GitHub Actions, add these as repository secrets (Settings → Secrets and variables → Actions).

# -------------------------------------------------------------------
# REQUIRED: Salesforce auth URL for the dev org.
# Generate with: sf org display --target-org dev-org --verbose --json
# Copy the value of "sfdxAuthUrl" from the output.
# In CI: add as secret named SFDX_AUTH_URL
# -------------------------------------------------------------------
SFDX_AUTH_URL=

# -------------------------------------------------------------------
# OPTIONAL: Override the default target org alias (default: dev-org)
# -------------------------------------------------------------------
SF_TARGET_ORG=dev-org

# -------------------------------------------------------------------
# OPTIONAL: sf CLI log level (error | warn | info | debug | trace)
# -------------------------------------------------------------------
SF_LOG_LEVEL=warn
